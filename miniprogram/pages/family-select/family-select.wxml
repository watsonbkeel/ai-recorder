<view class="page">
  <view class="card hero-card">
    <view class="hero-content">
      <image class="hero-image hero-image-compact" src="/images/loading-1.jpg" mode="aspectFill"></image>
      <view class="title page-title">暖心留声机</view>
      <view class="sub-title">选择一个家庭空间，把留声、暖心表达和家庭沟通习惯都留在这个家里。</view>
    </view>
  </view>

  <view wx:if="{{loading}}" class="loading">正在加载家庭...</view>
  <view wx:elif="{{error}}" class="error">{{error}}</view>

  <view wx:else>
    <view wx:if="{{!families.length}}" class="empty">还没有家庭空间，先创建一个家。</view>
    <view wx:for="{{families}}" wx:key="id" class="card family-card" bindtap="selectFamily" data-item="{{item}}">
      <view class="row-between">
        <view>
          <view class="title">{{item.name}}</view>
          <view class="sub-title">{{item.description || '家人的心声都会在这里被好好保存'}}</view>
        </view>
        <view class="tag">{{item.role === 'admin' ? '管理员' : '成员'}}</view>
      </view>
      <view class="muted" style="margin-top:12rpx;">邀请码：{{item.inviteCode}}</view>
    </view>

    <view class="card">
      <view class="title">创建家庭</view>
      <view class="sub-title">为家人准备一个只属于这个家庭的暖心留声空间。</view>
      <input class="input" placeholder="家庭名称，例如：我们家" value="{{createName}}" bindinput="handleNameInput" />
      <textarea class="textarea" placeholder="一句家庭介绍，可不填" value="{{createDescription}}" bindinput="handleDescriptionInput"></textarea>
      <view class="section-title">点选你在家里的位置</view>
      <view class="family-layout">
        <view class="slot-row slot-row-parents">
          <view wx:for="{{familySlots}}" wx:key="key" wx:if="{{item.group === 'parent'}}" class="family-slot {{item.selected ? 'family-slot-selected' : ''}}" data-key="{{item.key}}" bindtap="selectIdentitySlot">
            <view class="slot-avatar">{{item.avatarText}}</view>
            <view class="slot-title">{{item.displayLabel}}</view>
            <view class="slot-status">{{item.selected ? '已选择' : '点选'}}</view>
          </view>
        </view>
        <view class="slot-row slot-row-children">
          <view wx:for="{{familySlots}}" wx:key="key" wx:if="{{item.group === 'child'}}" class="family-slot child-slot {{item.selected ? 'family-slot-selected' : ''}}" data-key="{{item.key}}" bindtap="selectIdentitySlot">
            <view class="slot-avatar">{{item.avatarText}}</view>
            <view class="slot-title">{{item.displayLabel}}</view>
            <view class="slot-status">{{item.selected ? '已选择' : '点选'}}</view>
          </view>
        </view>
      </view>
      <picker wx:if="{{showChildRelationship}}" mode="selector" range="{{childRelationshipLabels}}" value="{{childRelationshipIndex}}" bindchange="handleChildRelationshipChange">
        <view class="input">这个位置是：{{childRelationshipLabels[childRelationshipIndex]}}</view>
      </picker>
      <input class="input" type="number" placeholder="出生年份，可不填" value="{{birthYear}}" bindinput="handleBirthYearInput" />
      <input class="input" placeholder="家庭昵称，例如 爸爸、小明、妹妹" value="{{familyNickname}}" bindinput="handleFamilyNicknameInput" />
      <input class="input" placeholder="希望被称呼，例如 爸、姐姐" value="{{preferredTitle}}" bindinput="handlePreferredTitleInput" />
      <textarea class="textarea" placeholder="身份备注，例如 异地上大学、工作较忙，可不填" value="{{identityNote}}" bindinput="handleIdentityNoteInput"></textarea>
      <button class="btn-primary" loading="{{creating}}" disabled="{{creating}}" bindtap="createFamily">创建并进入</button>
    </view>

    <view class="card soft-panel">
      <button class="btn-secondary" bindtap="goJoin">通过邀请码加入家庭</button>
    </view>
  </view>
</view>
