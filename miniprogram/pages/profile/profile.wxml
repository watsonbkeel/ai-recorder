<view class="page">
  <view wx:if="{{loading}}" class="loading">加载中...</view>
  <view wx:elif="{{error}}" class="error">{{error}}</view>
  <block wx:else>
    <view class="card hero-card">
      <view class="title">{{user.nickname || '家庭成员'}}</view>
      <view class="sub-title">当前家庭：{{currentFamily ? currentFamily.name : '未选择'}}</view>
      <view wx:if="{{currentFamily}}" class="muted">
        {{currentFamily.identityText || currentFamily.relationshipLabel}} {{currentFamily.familyNickname ? '· ' + currentFamily.familyNickname : ''}}
      </view>
      <view wx:if="{{currentFamily && currentFamily.role === 'admin'}}" class="actions">
        <button class="btn-secondary" bindtap="goAdmin">进入家庭管理</button>
      </view>
    </view>

    <view class="card">
      <view class="title">我的昵称</view>
      <view class="sub-title">全局昵称作为默认展示名，家庭昵称只在当前家庭内使用。</view>
      <input class="input" placeholder="全局昵称" value="{{nicknameInput}}" bindinput="handleNicknameInput" />
      <input class="input" placeholder="头像 URL（可选）" value="{{avatarUrlInput}}" bindinput="handleAvatarUrlInput" />
      <button class="btn-primary" loading="{{savingProfile}}" disabled="{{savingProfile}}" bindtap="saveProfile">保存昵称</button>
    </view>

    <view wx:if="{{currentFamily}}" class="card">
      <view class="title">家庭身份</view>
      <view class="sub-title">身份只用于称呼、语气和表达适配，帮助话说得更清楚，不用于评价家人或贴标签。</view>
      <picker mode="selector" range="{{relationshipLabels}}" value="{{relationshipIndex}}" bindchange="handleRelationshipChange">
        <view class="input">关系：{{relationshipLabels[relationshipIndex]}}</view>
      </picker>
      <picker mode="selector" range="{{genderLabels}}" value="{{genderIndex}}" bindchange="handleGenderChange">
        <view class="input">性别：{{genderLabels[genderIndex]}}</view>
      </picker>
      <input wx:if="{{showChildOrder}}" class="input" type="number" placeholder="子女排行，例如 1 表示老大，可不填" value="{{childOrder}}" bindinput="handleChildOrderInput" />
      <input class="input" type="number" placeholder="出生年份，可不填" value="{{birthYear}}" bindinput="handleBirthYearInput" />
      <input class="input" placeholder="家庭昵称，例如 小明、妈妈" value="{{familyNickname}}" bindinput="handleFamilyNicknameInput" />
      <input class="input" placeholder="希望被称呼，例如 爸、姐姐" value="{{preferredTitle}}" bindinput="handlePreferredTitleInput" />
      <textarea class="textarea" placeholder="身份备注，例如 异地上学、工作较忙，可不填" value="{{identityNote}}" bindinput="handleIdentityNoteInput"></textarea>
      <button class="btn-primary" loading="{{savingIdentity}}" disabled="{{savingIdentity}}" bindtap="saveIdentity">保存家庭身份</button>
    </view>

    <view class="card">
      <view class="title">我的家庭</view>
      <view wx:if="{{!families.length}}" class="empty">暂无已加入家庭。</view>
      <view wx:for="{{families}}" wx:key="id" class="family-row">
        <view>
          <view>{{item.name}}</view>
          <view class="muted">{{item.role === 'admin' ? '管理员' : '成员'}} · {{item.identityText || item.relationshipLabel}} {{item.isMuted ? '· 已停用留言' : ''}}</view>
        </view>
        <button size="mini" class="btn-secondary" data-item="{{item}}" bindtap="switchFamily">切换</button>
      </view>
    </view>

    <view class="card">
      <button class="btn-danger" bindtap="logout">退出登录</button>
    </view>
  </block>
</view>
