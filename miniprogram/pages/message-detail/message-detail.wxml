<view class="page">
  <view wx:if="{{loading}}" class="loading">加载中...</view>
  <view wx:elif="{{error && !message}}" class="error">{{error}}</view>

  <block wx:elif="{{message}}">
    <view wx:if="{{error}}" class="error inline-error">{{error}}</view>

    <view class="card message-card">
      <view class="row-between">
        <view>
          <view class="card-title-small">{{message.sender.nickname}}</view>
          <view class="identity-line">家庭身份：{{message.senderIdentitySummary}}</view>
          <view class="muted">{{message.visibilityText}} · {{message.createdAtText}}</view>
        </view>
      </view>
      <view class="message-body">{{message.optimizedText}}</view>

      <view class="message-meta">
        <text wx:for="{{message.emotionTags}}" wx:key="*this" class="tag tag-peach">{{item}}</text>
      </view>
      <view wx:if="{{message.coreNeed}}" class="muted message-meta">想说清楚的是：{{message.coreNeed}}</view>
      <view wx:if="{{message.aiAdvice}}" class="muted message-meta">表达提示：{{message.aiAdvice}}</view>
      <view wx:if="{{message.riskLevel === 'high' || message.riskLevel === 'medium' || message.attackWarning}}" class="risk-panel">
        <view class="risk-title">安全提醒</view>
        <view wx:if="{{message.attackWarning}}" class="risk-text">{{message.attackWarning}}</view>
        <view wx:else class="risk-text">这段心声可能会让沟通变得紧张，回应前可以先放慢节奏，保护好彼此的边界。</view>
      </view>
      <view wx:if="{{message.canDelete || message.canHide}}" class="actions">
        <button wx:if="{{message.canDelete}}" class="btn-danger" size="mini" loading="{{handlingMessageAction === 'delete'}}" disabled="{{handlingMessageAction}}" bindtap="deleteMessage">删除留言</button>
        <button wx:if="{{message.canHide}}" class="btn-danger" size="mini" loading="{{handlingMessageAction === 'hide'}}" disabled="{{handlingMessageAction}}" bindtap="hideMessage">隐藏留言</button>
      </view>
    </view>

    <view class="card">
      <view class="title">原始表达</view>
      <view class="sub-title">原话可能带有情绪，请尝试理解情绪背后的真实需求。</view>
      <view wx:if="{{message.originalText}}" class="message-body">{{message.originalText}}</view>
      <button wx:if="{{message.originalAudioUrl}}" class="btn-secondary" loading="{{playingOriginalAudio}}" disabled="{{playingOriginalAudio}}" bindtap="playOriginalAudio">{{playingOriginalAudio ? '播放中' : '播放原始语音'}}</button>
      <view wx:if="{{!message.originalText && !message.originalAudioUrl}}" class="muted" style="margin-top:16rpx;">发送者没有开放原始文字或语音。</view>
    </view>

    <view class="card">
      <view class="title">表达助手</view>
      <view class="row-between memory-row">
        <view>
          <view>参考家庭沟通习惯</view>
          <view class="muted">只参考这个家庭里你有权限看到的摘要、敏感点和有效表达。</view>
        </view>
        <switch checked="{{useFamilyMemory}}" bindchange="handleMemorySwitch"></switch>
      </view>
      <button class="btn-secondary" loading="{{analysisLoading}}" disabled="{{analysisLoading}}" bindtap="analyzeMessage">帮我更好理解</button>
      <view wx:if="{{analysisStatusText}}" class="ai-status">{{analysisStatusText}}</view>
      <view wx:if="{{analysis}}" class="analysis-box">
        <view wx:if="{{analysis.possibleEmotions && analysis.possibleEmotions.length}}" class="analysis-section">
          <view class="muted">可能传达的感受</view>
          <text wx:for="{{analysis.possibleEmotions}}" wx:key="*this" class="tag">{{item}}</text>
        </view>
        <view wx:if="{{analysis.realNeeds && analysis.realNeeds.length}}" class="analysis-section">
          <view class="muted">想被理解的地方</view>
          <view wx:for="{{analysis.realNeeds}}" wx:key="*this" class="list-line">{{item}}</view>
        </view>
        <view wx:if="{{analysis.whatToAvoid && analysis.whatToAvoid.length}}" class="analysis-section">
          <view class="muted">回应时避免</view>
          <view wx:for="{{analysis.whatToAvoid}}" wx:key="*this" class="list-line">{{item}}</view>
        </view>
        <view wx:if="{{analysis.suggestedResponse}}" class="analysis-section">
          <view class="muted">可以这样回应</view>
          <view class="suggested-response">{{analysis.suggestedResponse}}</view>
        </view>
        <view wx:if="{{analysis.riskLevel === 'high'}}" class="risk-panel">
          <view class="risk-title">安全提醒</view>
          <view class="risk-text">如果这段沟通涉及伤害、威胁、控制或无法独自承受的压力，请先保护自己，并寻求可信家人或专业支持。</view>
        </view>
      </view>
    </view>

    <view wx:if="{{message.visibility !== 'self'}}" class="card">
      <view class="preview-heading">
        <view class="title">回复家人</view>
        <picker mode="selector" range="{{previewModelLabels}}" value="{{previewModelIndex}}" bindchange="handlePreviewModelChange">
          <view class="preview-model">{{previewModelLabels[previewModelIndex]}}⌄</view>
        </picker>
      </view>

      <textarea class="composer-textarea {{inputMode === 'voice' ? 'readonly' : ''}}" adjust-position="{{true}}" auto-height placeholder="直接写下回复，或录音转成文字" value="{{replyOriginalText}}" bindinput="handleReplyInput" disabled="{{inputMode === 'voice' || transcribing}}"></textarea>

      <view class="chat-composer">
        <view class="composer-action-row">
          <button class="mode-toggle" disabled="{{aiLoading || transcribing || submitting}}" bindtap="toggleInputMode">
            {{inputMode === 'voice' ? '⌨️ 文字' : '🎤 语音'}}
          </button>
          <view class="composer-spacer"></view>
          <button class="composer-save" loading="{{aiLoading}}" disabled="{{aiLoading || recording || transcribing || submitting}}" bindtap="optimizeReply">{{aiLoading ? '整理中' : '暖心整理'}}</button>
        </view>

        <view wx:if="{{inputMode === 'voice'}}" class="hold-voice-row">
          <view class="hold-voice {{recording ? (isCancelVoice ? 'hold-voice-cancel' : 'hold-voice-active') : ''}} {{transcribing ? 'hold-voice-disabled' : ''}}"
                catchtouchstart="handleVoiceTouchStart"
                catchtouchmove="handleVoiceTouchMove"
                catchtouchend="handleVoiceTouchEnd"
                catchtouchcancel="handleVoiceTouchCancel">
            {{recording ? (isCancelVoice ? '松手取消录音' : '松手保存，上滑取消') : (transcribing ? '正在处理留声' : '按住说话')}}
          </view>
        </view>
      </view>

      <view wx:if="{{replyTranscribeStatus}}" class="voice-note">{{replyTranscribeStatus}}</view>

      <view class="row-between memory-row" style="margin-top:20rpx;">
        <view>
          <view>参考家庭沟通习惯</view>
          <view class="muted">关闭后，AI 只参考这条可见留言和你的回复原意。</view>
        </view>
        <switch checked="{{useFamilyMemory}}" bindchange="handleMemorySwitch"></switch>
      </view>

      <view wx:if="{{replyAiStatusText}}" class="ai-status">{{replyAiStatusText}}</view>

      <block wx:if="{{replyOptimizedText}}">
        <view style="margin-top: 30rpx; padding-top: 30rpx; border-top: 2rpx dashed var(--line-soft);">
          <view class="sub-title" style="margin-bottom: 16rpx;">发送前表达 (可手动修改)</view>
          <textarea class="textarea" value="{{replyOptimizedText}}" bindinput="handleReplyOptimizedInput"></textarea>
          <button class="btn-submit" loading="{{submitting}}" disabled="{{submitting || aiLoading || recording || transcribing}}" bindtap="submitReply">确认发送回复</button>
        </view>
      </block>
    </view>
    <view wx:else class="card">
      <view class="title">自留心声</view>
      <view class="sub-title">这条留言只用于整理自己的想法，不通知家人，也不需要回复。</view>
    </view>

    <view wx:if="{{message.visibility !== 'self' && !replies.length}}" class="empty">还没有回复。</view>
    <view wx:for="{{replies}}" wx:key="id" class="card">
      <view class="row-between">
        <view>
          <view class="card-title-small">{{item.sender.nickname}}</view>
          <view class="identity-line">家庭身份：{{item.senderIdentitySummary}}</view>
        </view>
        <view class="muted">{{item.createdAtText}}</view>
      </view>
      <view class="message-body">{{item.optimizedText}}</view>
      <view wx:if="{{item.riskLevel === 'high' || item.riskLevel === 'medium' || item.attackWarning}}" class="risk-panel">
        <view class="risk-title">安全提醒</view>
        <view wx:if="{{item.attackWarning}}" class="risk-text">{{item.attackWarning}}</view>
        <view wx:else class="risk-text">这条回复可能会让沟通变得紧张，继续交流前可以先确认彼此能平静听见。</view>
      </view>
      <view wx:if="{{item.canDelete || item.canHide}}" class="actions">
        <button wx:if="{{item.canDelete}}" class="btn-danger" size="mini" loading="{{handlingReplyId === item.id && handlingReplyAction === 'delete'}}" disabled="{{handlingReplyId}}" data-id="{{item.id}}" bindtap="deleteReply">删除回复</button>
        <button wx:if="{{item.canHide}}" class="btn-danger" size="mini" loading="{{handlingReplyId === item.id && handlingReplyAction === 'hide'}}" disabled="{{handlingReplyId}}" data-id="{{item.id}}" bindtap="hideReply">隐藏回复</button>
      </view>
    </view>
  </block>
</view>
