.analysis-box {
    margin-top: 20rpx;
    padding: 22rpx 24rpx;
    border: 2rpx solid rgba(199, 234, 216, 0.9);
    border-radius: 24rpx;
    background: linear-gradient(135deg, rgba(232, 246, 238, 0.96), rgba(255, 248, 236, 0.96));
  }

  .inline-error {
    padding: 24rpx;
    margin-bottom: 20rpx;
    background: var(--danger-soft);
    border-radius: 20rpx;
    color: var(--danger);
  }

  .analysis-section {
    margin-top: 18rpx;
  }

  .list-line {
    margin-top: 10rpx;
    color: var(--text-main);
    line-height: 42rpx;
  }

  .suggested-response {
    margin-top: 12rpx;
    color: var(--text-main);
    line-height: 44rpx;
    white-space: pre-wrap;
  }

  /* 以下为新增的回复区交互样式 */
  .preview-heading {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16rpx;
    margin-bottom: 16rpx;
  }

  .preview-model {
    min-height: 56rpx;
    padding: 0 20rpx;
    border: 2rpx solid rgba(234, 218, 200, 0.9);
    border-radius: 999rpx;
    background: #fffdf8;
    color: var(--text-muted);
    font-size: 24rpx;
    line-height: 56rpx;
    white-space: nowrap;
  }

  .composer-textarea {
    width: 100%;
    min-height: 140rpx;
    max-height: 240rpx;
    padding: 18rpx 22rpx;
    box-sizing: border-box;
    border: 2rpx solid var(--line-soft);
    border-radius: 22rpx;
    background: #fffdf8;
    color: var(--text-main);
    font-size: 30rpx;
    line-height: 42rpx;
    margin-bottom: 20rpx;
    transition: all 0.3s ease;
  }

  .composer-textarea.readonly {
    background: rgba(245, 245, 245, 0.6);
    border-color: transparent;
    color: var(--text-muted);
  }

  .chat-composer {
    display: flex;
    flex-direction: column;
    gap: 20rpx;
  }

  .composer-action-row {
    display: flex;
    align-items: center;
    width: 100%;
  }

  .mode-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0 32rpx;
    height: 72rpx;
    border: 2rpx solid rgba(199, 234, 216, 0.95);
    border-radius: 36rpx;
    background: var(--bg-mint-soft, #e8f6ee);
    color: var(--mint-deep, #2b7a54);
    font-size: 28rpx;
    box-shadow: var(--shadow-tiny);
    margin: 0;
  }

  .composer-spacer {
    flex: 1;
  }

  .composer-save {
    display: inline-flex !important;
    align-items: center;
    justify-content: center;
    width: 160rpx !important;
    min-width: 160rpx;
    height: 72rpx;
    padding: 0;
    background: linear-gradient(135deg, var(--brand), #ef9a79);
    color: #fffaf3;
    font-size: 28rpx;
    border-radius: 36rpx;
    box-shadow: 0 6rpx 16rpx rgba(223, 125, 98, 0.24);
    margin: 0;
    box-sizing: border-box;
  }

  .hold-voice-row {
    width: 100%;
  }

  .hold-voice {
    width: 100%;
    height: 88rpx;
    border: 2rpx solid rgba(234, 218, 200, 0.9);
    border-radius: 44rpx;
    background: linear-gradient(135deg, rgba(255, 248, 236, 0.98), rgba(232, 246, 238, 0.9));
    color: var(--text-main);
    font-size: 32rpx;
    font-weight: 700;
    line-height: 84rpx;
    text-align: center;
    box-shadow: var(--shadow-tiny);
    transition: all 0.2s ease;
  }

  .hold-voice-active {
    border-color: rgba(223, 125, 98, 0.48);
    background: linear-gradient(135deg, var(--bg-peach-soft), #fff8ec);
    color: var(--brand-deep);
    transform: translateY(2rpx);
  }

  .hold-voice-cancel {
    border-color: rgba(255, 77, 79, 0.6);
    background: linear-gradient(135deg, #fff1f0, #ffe5e5);
    color: #ff4d4f;
    transform: translateY(0);
  }

  .hold-voice-disabled {
    opacity: 0.62;
  }

  .voice-note {
    font-size: 24rpx;
    color: var(--text-muted);
    margin-top: 10rpx;
    text-align: center;
  }

  .btn-submit {
    width: 100% !important;
    height: 88rpx;
    line-height: 88rpx;
    margin-top: 20rpx;
    border-radius: 44rpx;
    background: linear-gradient(135deg, var(--brand), #ef9a79);
    color: #fffaf3;
    font-size: 32rpx;
    font-weight: 700;
    text-align: center;
    box-shadow: 0 10rpx 24rpx rgba(223, 125, 98, 0.3);
  }
