.analysis-box {
  margin-top: 20rpx;
  padding: 22rpx 24rpx;
  border: 2rpx solid rgba(199, 234, 216, 0.9);
  border-radius: 24rpx;
  background: linear-gradient(135deg, rgba(232, 246, 238, 0.96), rgba(255, 248, 236, 0.96));
}

.inline-error {
  padding: 24rpx;
  margin-bottom: 20rpx;
  background: var(--danger-soft);
  border-radius: 20rpx;
  color: var(--danger);
}

.analysis-section {
  margin-top: 18rpx;
}

.list-line {
  margin-top: 10rpx;
  color: var(--text-main);
  line-height: 42rpx;
}

.suggested-response {
  margin-top: 12rpx;
  color: var(--text-main);
  line-height: 44rpx;
  white-space: pre-wrap;
}
