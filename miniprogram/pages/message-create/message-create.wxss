/* 输入卡片整体 */
.composer-card {
    margin-top: 20rpx;
    padding: 20rpx;
    border: 2rpx solid rgba(234, 218, 200, 0.78);
    border-radius: 26rpx;
    background: rgba(255, 252, 246, 0.78);
    box-shadow: inset 0 2rpx 8rpx rgba(126, 92, 72, 0.04);
  }
  
  .composer-type {
    min-height: 68rpx;
    color: var(--text-muted);
    font-size: 26rpx;
    line-height: 68rpx;
  }
  
  /* 多行文本框：去掉了所有切换相关的逻辑，给了一个更舒适的默认高度 */
  .composer-textarea {
    width: 100%;
    min-height: 180rpx; 
    padding: 18rpx 22rpx;
    box-sizing: border-box;
    border: 2rpx solid var(--line-soft);
    border-radius: 22rpx;
    background: #fffdf8;
    color: var(--text-main);
    font-size: 30rpx;
    line-height: 42rpx;
    margin-bottom: 20rpx;
  }
  
  /* 控制栏：只留下生成预览按钮，并把它推到右侧 */
  .chat-composer {
    display: flex;
    align-items: center;
    width: 100%;
  }
  
  .composer-spacer {
    flex: 1;
  }
  
  /* 生成预览按钮 */
  .composer-save {
    width: 160rpx !important;
    min-width: 160rpx;
    height: 72rpx;
    padding: 0;
    background: linear-gradient(135deg, var(--brand), #ef9a79);
    color: #fffaf3;
    font-size: 28rpx;
    line-height: 72rpx;
    text-align: center;
    border-radius: 36rpx;
    box-shadow: 0 6rpx 16rpx rgba(223, 125, 98, 0.24);
    margin: 0;
  }
  
  .composer-hint {
    margin-top: 14rpx;
    color: var(--text-muted);
    font-size: 24rpx;
    line-height: 36rpx;
  }
  
  /* 底部最终确认发送按钮 */
  .btn-submit {
    width: 100% !important;
    height: 88rpx;
    line-height: 88rpx;
    margin-top: 32rpx;
    border-radius: 44rpx;
    background: linear-gradient(135deg, var(--brand), #ef9a79);
    color: #fffaf3;
    font-size: 32rpx;
    font-weight: 700;
    text-align: center;
    box-shadow: 0 10rpx 24rpx rgba(223, 125, 98, 0.3);
    transition: all 0.2s ease;
  }
  
  .btn-submit:active {
    transform: scale(0.98);
    opacity: 0.9;
  }
