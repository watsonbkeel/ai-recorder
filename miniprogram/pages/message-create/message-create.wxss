.composer-card {
  margin-top: 20rpx;
  padding: 20rpx;
  border: 2rpx solid rgba(234, 218, 200, 0.78);
  border-radius: 26rpx;
  background: rgba(255, 252, 246, 0.78);
  box-shadow: inset 0 2rpx 8rpx rgba(126, 92, 72, 0.04);
}

.composer-type {
  min-height: 68rpx;
  color: var(--text-muted);
  font-size: 26rpx;
  line-height: 68rpx;
}

.chat-composer {
  display: flex;
  align-items: flex-end;
  gap: 14rpx;
}

.mode-toggle {
  width: 76rpx;
  min-width: 76rpx;
  height: 76rpx;
  min-height: 76rpx;
  padding: 0;
  border: 2rpx solid rgba(199, 234, 216, 0.95);
  border-radius: 50%;
  background: var(--bg-mint-soft);
  color: var(--mint-deep);
  font-size: 30rpx;
  line-height: 72rpx;
  box-shadow: var(--shadow-tiny);
}

.composer-textarea {
  flex: 1;
  min-height: 76rpx;
  max-height: 220rpx;
  padding: 18rpx 22rpx;
  box-sizing: border-box;
  border: 2rpx solid var(--line-soft);
  border-radius: 22rpx;
  background: #fffdf8;
  color: var(--text-main);
  font-size: 30rpx;
  line-height: 42rpx;
}

.hold-voice {
  flex: 1;
  height: 76rpx;
  border: 2rpx solid rgba(234, 218, 200, 0.9);
  border-radius: 22rpx;
  background: linear-gradient(135deg, rgba(255, 248, 236, 0.98), rgba(232, 246, 238, 0.9));
  color: var(--text-main);
  font-size: 30rpx;
  font-weight: 700;
  line-height: 76rpx;
  text-align: center;
  box-shadow: var(--shadow-tiny);
}

.hold-voice-active {
  border-color: rgba(223, 125, 98, 0.48);
  background: linear-gradient(135deg, var(--bg-peach-soft), #fff8ec);
  color: var(--brand-deep);
  transform: translateY(2rpx);
}

.hold-voice-disabled {
  opacity: 0.62;
}

.composer-save {
  width: 112rpx;
  min-width: 112rpx;
  height: 76rpx;
  min-height: 76rpx;
  padding: 0;
  background: linear-gradient(135deg, var(--brand), #ef9a79);
  color: #fffaf3;
  font-size: 26rpx;
  line-height: 76rpx;
  box-shadow: 0 10rpx 22rpx rgba(223, 125, 98, 0.24);
}

.composer-hint {
  margin-top: 14rpx;
  color: var(--text-muted);
  font-size: 24rpx;
  line-height: 36rpx;
}
