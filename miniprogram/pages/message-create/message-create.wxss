.section-title {
  margin-top: 24rpx;
  margin-bottom: 12rpx;
  font-weight: 700;
  color: #0f172a;
}

.member-option {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx;
  margin-top: 14rpx;
  border: 2rpx solid #dbe3ec;
  border-radius: 14rpx;
  background: #f8fafc;
}

.member-option-selected {
  border-color: #25636f;
  background: #eef8f7;
}

.member-name {
  font-weight: 700;
  color: #0f172a;
}

.memory-row {
  gap: 20rpx;
  margin: 24rpx 0;
  padding: 20rpx;
  border: 2rpx solid #dbe3ec;
  border-radius: 14rpx;
  background: #f8fafc;
}
