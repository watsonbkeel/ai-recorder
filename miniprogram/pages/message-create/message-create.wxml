<view class="page">
  <view class="card">
    <view class="title">写给家人</view>
    <view class="sub-title">先写下文字原话或语音大意，再让 AI 帮你整理表达。</view>

    <picker mode="selector" range="{{visibilityLabels}}" value="{{visibilityIndex}}" bindchange="handleVisibilityChange">
      <view class="input">留言范围：{{visibilityLabels[visibilityIndex]}}</view>
    </picker>
    <view class="muted">{{visibilityDescriptions[visibilityIndex]}}</view>

    <block wx:if="{{visibilityIndex === 0}}">
      <view class="section-title">接收家人</view>
      <view wx:if="{{membersLoading}}" class="muted">正在加载家庭成员...</view>
      <view wx:elif="{{!members.length}}" class="muted">这个家庭还没有其他成员。</view>
      <view wx:for="{{members}}" wx:key="userId" class="member-option {{item.selected ? 'member-option-selected' : ''}}" data-user-id="{{item.userId}}" bindtap="toggleReceiver">
        <view>
          <view class="member-name">{{item.displayName}}</view>
          <view class="muted">{{item.identitySummary}}</view>
        </view>
        <view class="tag">{{item.selected ? '已选择' : '选择'}}</view>
      </view>
    </block>

    <picker mode="selector" range="{{messageTypeLabels}}" value="{{messageTypeIndex}}" bindchange="handleTypeChange">
      <view class="input">留言类型：{{messageTypeLabels[messageTypeIndex]}}</view>
    </picker>
    <textarea class="textarea" placeholder="写下原话，哪怕有点乱也没关系" value="{{originalText}}" bindinput="handleOriginalInput"></textarea>

    <view class="actions">
      <button class="btn-secondary" disabled="{{loading || aiLoading || recording || playingAudio}}" bindtap="startRecord">开始录音</button>
      <button class="btn-secondary" disabled="{{loading || !recording}}" bindtap="stopRecord">停止录音</button>
      <button wx:if="{{audioTempPath}}" class="btn-secondary" loading="{{playingAudio}}" disabled="{{loading || aiLoading || recording || playingAudio}}" bindtap="playAudio">{{playingAudio ? '试听中' : '试听原声'}}</button>
    </view>
    <view wx:if="{{audioTempPath}}" class="muted">已录制语音，发送时会上传。当前版本不会自动转写语音，AI 整理需要你先写下文字原话或大意。</view>

    <view class="row-between memory-row">
      <view>
        <view>使用家庭沟通记忆</view>
        <view class="muted">参考本家庭内可见摘要、敏感点和有效表达。</view>
      </view>
      <switch checked="{{useFamilyMemory}}" bindchange="handleMemorySwitch"></switch>
    </view>

    <button class="btn-secondary" loading="{{aiLoading}}" disabled="{{loading || aiLoading || recording || playingAudio}}" bindtap="optimize">AI 帮我整理文字表达</button>
    <view wx:if="{{aiStatusText}}" class="ai-status">{{aiStatusText}}</view>
  </view>

  <view wx:if="{{originalText || optimizedText || audioTempPath}}" class="card">
    <view class="title">发送前表达</view>
    <view wx:if="{{audioTempPath && !originalText && !optimizedText}}" class="sub-title">如果这次只录了语音，请在这里手动写下希望家人先看到的整理版，再发送原声。</view>
    <textarea class="textarea" placeholder="默认使用上面的文字原话；也可以在这里手动改成更温和的整理版" value="{{optimizedText}}" bindinput="handleOptimizedInput"></textarea>
    <view wx:if="{{emotionTags.length}}">
      <text wx:for="{{emotionTags}}" wx:key="*this" class="tag">{{item}}</text>
    </view>
    <view wx:if="{{coreNeed}}" class="muted" style="margin-top:12rpx;">核心诉求：{{coreNeed}}</view>
    <view wx:if="{{aiAdvice}}" class="muted" style="margin-top:12rpx;">建议：{{aiAdvice}}</view>
    <view wx:if="{{visibilityIndex !== 2}}" class="row-between" style="margin-top:16rpx;">
      <view>允许对方看原始文字</view>
      <switch checked="{{allowOriginalTextView}}" bindchange="handleTextPermission"></switch>
    </view>
    <view wx:if="{{visibilityIndex !== 2}}" class="row-between" style="margin-top:16rpx;">
      <view>允许对方播放原始语音</view>
      <switch checked="{{allowOriginalAudioPlay}}" bindchange="handleAudioPermission"></switch>
    </view>
    <button class="btn-primary" loading="{{loading}}" disabled="{{loading || aiLoading || recording || playingAudio}}" bindtap="submit">{{visibilityIndex === 2 ? '保存心声' : '发送心声'}}</button>
  </view>

  <view wx:if="{{error}}" class="error">{{error}}</view>
</view>
