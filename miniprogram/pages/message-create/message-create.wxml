<view class="page">
  <view class="card">
    <view class="title">写给家人</view>
    <view class="sub-title">先保留真实心声，再让 AI 帮你整理表达。</view>

    <input class="input" placeholder="接收人用户ID，多个用逗号分隔" value="{{receiverText}}" bindinput="handleReceiverInput" />
    <picker mode="selector" range="{{messageTypeLabels}}" value="{{messageTypeIndex}}" bindchange="handleTypeChange">
      <view class="input">留言类型：{{messageTypeLabels[messageTypeIndex]}}</view>
    </picker>
    <textarea class="textarea" placeholder="写下原话，哪怕有点乱也没关系" value="{{originalText}}" bindinput="handleOriginalInput"></textarea>

    <view class="actions">
      <button class="btn-secondary" disabled="{{loading || recording}}" bindtap="startRecord">开始录音</button>
      <button class="btn-secondary" disabled="{{loading || !recording}}" bindtap="stopRecord">停止录音</button>
      <button wx:if="{{audioTempPath}}" class="btn-secondary" disabled="{{loading}}" bindtap="playAudio">试听原声</button>
    </view>
    <view wx:if="{{audioTempPath}}" class="muted">已录制语音，发送时会上传。</view>

    <button class="btn-secondary" loading="{{aiLoading}}" disabled="{{loading || aiLoading}}" bindtap="optimize">AI 帮我整理表达</button>
  </view>

  <view wx:if="{{optimizedText}}" class="card">
    <view class="title">AI 整理版</view>
    <textarea class="textarea" value="{{optimizedText}}" bindinput="handleOptimizedInput"></textarea>
    <view wx:if="{{emotionTags.length}}">
      <text wx:for="{{emotionTags}}" wx:key="*this" class="tag">{{item}}</text>
    </view>
    <view wx:if="{{coreNeed}}" class="muted" style="margin-top:12rpx;">核心诉求：{{coreNeed}}</view>
    <view wx:if="{{aiAdvice}}" class="muted" style="margin-top:12rpx;">建议：{{aiAdvice}}</view>
    <view class="row-between" style="margin-top:16rpx;">
      <view>允许对方看原始文字</view>
      <switch checked="{{allowOriginalTextView}}" bindchange="handleTextPermission"></switch>
    </view>
    <view class="row-between" style="margin-top:16rpx;">
      <view>允许对方播放原始语音</view>
      <switch checked="{{allowOriginalAudioPlay}}" bindchange="handleAudioPermission"></switch>
    </view>
    <button class="btn-primary" loading="{{loading}}" disabled="{{loading}}" bindtap="submit">发送心声</button>
  </view>

  <view wx:if="{{error}}" class="error">{{error}}</view>
</view>
