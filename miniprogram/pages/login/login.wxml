<view class="page">
  <view class="card">
    <view class="title">暖心留声机</view>
    <view class="sub-title">使用微信登录进入家庭空间；本地调试也可以使用账号名和密码。</view>
    <view class="help-list">
      <view class="help-item"><view class="help-index">1</view><view class="help-text">推荐使用微信登录，首次登录会自动创建账号。</view></view>
      <view class="help-item"><view class="help-index">2</view><view class="help-text">进入家庭后就能给家人留言、听原声、回复和查看通知。</view></view>
    </view>
    <input class="input" placeholder="昵称（可选）" value="{{nickname}}" bindinput="handleNicknameInput" />
    <button class="btn-primary" loading="{{loading}}" disabled="{{loading}}" bindtap="handleWechatLogin">微信登录 / 注册</button>
    <view class="divider"></view>
    <view class="tag">{{mode === 'login' ? '账号登录' : '注册新账号'}}</view>
    <input class="input" placeholder="账号名（3-32位字母/数字）" value="{{accountName}}" bindinput="handleAccountInput" />
    <input class="input" password="true" placeholder="密码（至少6位）" value="{{password}}" bindinput="handlePasswordInput" />
    <button class="btn-primary" loading="{{loading}}" disabled="{{loading}}" bindtap="handleSubmit">{{mode === 'login' ? '登录' : '注册并登录'}}</button>
    <button class="btn-secondary" disabled="{{loading}}" bindtap="switchMode">{{mode === 'login' ? '没有账号？去注册' : '已有账号？去登录'}}</button>
  </view>
  <view wx:if="{{loading}}" class="loading">处理中...</view>
  <view wx:if="{{error}}" class="error">{{error}}</view>
</view>
