<view class="page">
  <view class="card row-between hero-card">
    <view>
      <view class="title">{{currentFamily ? currentFamily.name : '家庭心声'}}</view>
      <view class="sub-title">先听见心里话，再把回应放慢一点。</view>
    </view>
    <view class="row">
      <button size="mini" class="btn-secondary" bindtap="goNotifications">通知{{unreadCount ? '(' + unreadCount + ')' : ''}}</button>
      <button size="mini" class="btn-secondary" bindtap="goProfile">我的</button>
    </view>
  </view>

  <view wx:if="{{currentFamily && currentFamily.role === 'admin'}}" class="card">
    <view class="muted">邀请码：{{currentFamily.inviteCode}}</view>
  </view>

  <view wx:if="{{loading}}" class="loading">加载心声中...</view>
  <view wx:elif="{{error}}" class="error">{{error}}</view>
  <view wx:elif="{{empty}}" class="empty">还没有心声，写给家人第一句话吧。</view>

  <view wx:for="{{messages}}" wx:key="id" class="card message-card" bindtap="goDetail" data-id="{{item.id}}">
    <view class="row-between">
      <view>
        <view class="card-title-small">{{item.sender.nickname}}</view>
        <view class="identity-line">家庭身份：{{item.senderIdentitySummary}}</view>
        <view class="muted">{{item.messageTypeText}} · {{item.visibilityText}}</view>
      </view>
      <view class="muted">{{item.createdAtText}}</view>
    </view>
    <view class="message-body">{{item.optimizedText}}</view>
    <view style="margin-top:12rpx;">
      <text wx:for="{{item.emotionTags}}" wx:key="*this" class="tag">{{item}}</text>
    </view>
    <view wx:if="{{item.coreNeed}}" class="muted message-meta">想说清楚的是：{{item.coreNeed}}</view>
  </view>

  <view wx:if="{{loadingMore}}" class="loading">加载更多...</view>
  <view wx:if="{{!hasMore && messages.length}}" class="empty">没有更多了</view>

  <view class="fab" bindtap="goCreate">+</view>
</view>
