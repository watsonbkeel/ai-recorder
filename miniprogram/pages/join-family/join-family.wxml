<view class="page">
  <view class="card hero-card">
    <image class="hero-image hero-image-compact" src="/images/loading-1.jpg" mode="aspectFill"></image>
    <view class="title">加入家庭</view>
    <view class="sub-title">用家人给你的邀请码进入这个家庭留声空间，先确认身份，再开始留下心声。</view>
  </view>

  <view class="card">
    <input class="input" placeholder="输入家人给你的邀请码" value="{{inviteCode}}" bindinput="handleInviteInput" />
    <button class="btn-secondary" loading="{{loading}}" disabled="{{loading}}" bindtap="previewFamily">查看家庭位置</button>
    <textarea class="textarea" placeholder="给管理员留一句话，可不填" value="{{message}}" bindinput="handleMessageInput"></textarea>
    <view wx:if="{{familyPreview}}" class="soft-panel">
      <view class="title" style="font-size:30rpx;">{{familyPreview.name}}</view>
      <view class="muted">{{familyPreview.description || '选择你在这个家庭里的位置，方便管理员确认。'}}</view>
    </view>
    <view class="section-title">点选你在家里的位置</view>
    <view class="family-layout">
      <view class="slot-row slot-row-parents">
        <view wx:for="{{familySlots}}" wx:key="key" wx:if="{{item.group === 'parent'}}" class="family-slot {{item.selected ? 'family-slot-selected' : ''}} {{item.occupied ? 'family-slot-disabled' : ''}}" data-key="{{item.key}}" bindtap="selectIdentitySlot">
          <view class="slot-avatar">{{item.avatarText}}</view>
          <view class="slot-title">{{item.displayLabel}}</view>
          <view class="slot-status">{{item.occupied ? (item.member.displayName || '已认领') : (item.selected ? '已选择' : '点选')}}</view>
        </view>
      </view>
      <view class="slot-row slot-row-children">
        <view wx:for="{{familySlots}}" wx:key="key" wx:if="{{item.group === 'child'}}" class="family-slot child-slot {{item.selected ? 'family-slot-selected' : ''}} {{item.occupied ? 'family-slot-disabled' : ''}}" data-key="{{item.key}}" bindtap="selectIdentitySlot">
          <view class="slot-avatar">{{item.avatarText}}</view>
          <view class="slot-title">{{item.displayLabel}}</view>
          <view class="slot-status">{{item.occupied ? (item.member.displayName || '已认领') : (item.selected ? '已选择' : '点选')}}</view>
        </view>
      </view>
    </view>
    <picker wx:if="{{showChildRelationship}}" mode="selector" range="{{childRelationshipLabels}}" value="{{childRelationshipIndex}}" bindchange="handleChildRelationshipChange">
      <view class="input">这个位置是：{{childRelationshipLabels[childRelationshipIndex]}}</view>
    </picker>
    <input class="input" type="number" placeholder="出生年份，可不填" value="{{birthYear}}" bindinput="handleBirthYearInput" />
    <input class="input" placeholder="家庭昵称，例如 爸爸、小明、妹妹" value="{{familyNickname}}" bindinput="handleFamilyNicknameInput" />
    <input class="input" placeholder="希望被称呼，例如 爸、姐姐" value="{{preferredTitle}}" bindinput="handlePreferredTitleInput" />
    <textarea class="textarea" placeholder="身份备注，例如 异地上学、工作较忙，可不填" value="{{identityNote}}" bindinput="handleIdentityNoteInput"></textarea>
    <button class="btn-primary" loading="{{loading}}" disabled="{{loading}}" bindtap="submit">提交申请</button>
  </view>
  <view wx:if="{{error}}" class="error">{{error}}</view>
</view>
