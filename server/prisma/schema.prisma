generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum FamilyRole {
  member
  admin
}

enum FamilyRelationship {
  father
  mother
  son
  daughter
  child
  grandfather
  grandmother
  grandparent
  partner
  sibling
  other
}

enum FamilyGender {
  male
  female
  unspecified
}

enum JoinRequestStatus {
  pending
  approved
  rejected
}

enum ContentStatus {
  visible
  hidden
  deleted
}

enum MessageVisibility {
  private
  family
  self
}

enum FamilyMessageType {
  thanks
  apology
  grievance
  request
  explain
  stress
  repair
  encouragement
  general
}

enum RiskLevel {
  low
  medium
  high
}

enum MessageReceiverStatus {
  unread
  read
  replied
}

enum NotificationType {
  family_join_requested
  join_request_approved
  join_request_rejected
  message_received
  message_replied
}

enum FamilyAdminTargetType {
  join_request
  message
  reply
  member
}

enum FamilyAdminAction {
  approve_join_request
  reject_join_request
  hide_message
  hide_reply
  mute_member
  unmute_member
  remove_member
  set_admin
  unset_admin
  update_member_identity
}

enum FamilyMemoryScope {
  family
  member
  pair
}

enum FamilyMemoryStatus {
  active
  stale
}

model User {
  id                        Int                     @id @default(autoincrement())
  accountName               String?                 @unique @db.VarChar(191)
  passwordHash              String?                 @db.VarChar(255)
  wechatOpenid              String?                 @unique @db.VarChar(191)
  nickname                  String?                 @db.VarChar(191)
  avatarUrl                 String?                 @db.VarChar(500)
  isGlobalAdmin             Boolean                 @default(false)
  createdAt                 DateTime                @default(now())
  updatedAt                 DateTime                @updatedAt
  createdFamilies           Family[]                @relation("FamilyCreatedBy")
  familyMembers             FamilyMember[]
  familyJoinRequests        FamilyJoinRequest[]     @relation("FamilyJoinRequestUser")
  handledFamilyJoinRequests FamilyJoinRequest[]     @relation("FamilyJoinRequestHandledBy")
  familyMessages            FamilyMessage[]         @relation("FamilyMessageSender")
  familyReplies             FamilyReply[]           @relation("FamilyReplySender")
  receivedFamilyMessages    FamilyMessageReceiver[]
  notificationsReceived     Notification[]          @relation("NotificationReceiver")
  notificationsTriggered    Notification[]          @relation("NotificationActor")
  familyAdminLogs           FamilyAdminLog[]        @relation("FamilyAdminLogAdmin")
}

model Family {
  id            Int                 @id @default(autoincrement())
  name          String              @db.VarChar(191)
  description   String?             @db.Text
  inviteCode    String              @unique @db.VarChar(20)
  createdById   Int
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  createdBy     User                @relation("FamilyCreatedBy", fields: [createdById], references: [id])
  members       FamilyMember[]
  joinRequests  FamilyJoinRequest[]
  messages      FamilyMessage[]
  replies       FamilyReply[]
  notifications Notification[]
  adminLogs     FamilyAdminLog[]
  memories      FamilyMemory[]

  @@index([createdById])
}

model FamilyMember {
  id             Int                @id @default(autoincrement())
  familyId       Int
  userId         Int
  role           FamilyRole         @default(member)
  slotKey        String?            @db.VarChar(40)
  relationship   FamilyRelationship @default(other)
  gender         FamilyGender       @default(unspecified)
  childOrder     Int?
  birthYear      Int?
  familyNickname String?            @db.VarChar(191)
  preferredTitle String?            @db.VarChar(191)
  identityNote   String?            @db.VarChar(500)
  isMuted        Boolean            @default(false)
  joinedAt       DateTime           @default(now())
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  family         Family             @relation(fields: [familyId], references: [id], onDelete: Cascade)
  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  memories       FamilyMemory[]     @relation("FamilyMemoryMember")
  relatedMemories FamilyMemory[]    @relation("FamilyMemoryRelated")

  @@unique([familyId, userId])
  @@unique([familyId, slotKey])
  @@index([userId])
  @@index([familyId, role])
  @@index([familyId, relationship, childOrder])
}

model FamilyJoinRequest {
  id             Int               @id @default(autoincrement())
  familyId       Int
  userId         Int
  status         JoinRequestStatus @default(pending)
  message        String?           @db.Text
  slotKey        String?           @db.VarChar(40)
  relationship   FamilyRelationship @default(other)
  gender         FamilyGender      @default(unspecified)
  childOrder     Int?
  birthYear      Int?
  familyNickname String?           @db.VarChar(191)
  preferredTitle String?           @db.VarChar(191)
  identityNote   String?           @db.VarChar(500)
  handledById    Int?
  handledAt      DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  family         Family            @relation(fields: [familyId], references: [id], onDelete: Cascade)
  user           User              @relation("FamilyJoinRequestUser", fields: [userId], references: [id], onDelete: Cascade)
  handledBy      User?             @relation("FamilyJoinRequestHandledBy", fields: [handledById], references: [id], onDelete: SetNull)

  @@index([familyId, status])
  @@index([userId, status])
  @@index([familyId, userId])
  @@index([familyId, slotKey])
}

model FamilyMessage {
  id                     Int                     @id @default(autoincrement())
  familyId               Int
  senderId               Int
  visibility             MessageVisibility       @default(private)
  messageType            FamilyMessageType       @default(general)
  originalText           String?                 @db.Text
  originalAudioUrl       String?                 @db.VarChar(500)
  audioDurationSec       Int?
  optimizedText          String                  @db.Text
  emotionTags            Json?
  coreNeed               String?                 @db.Text
  aiAdvice               String?                 @db.Text
  riskLevel              RiskLevel               @default(low)
  attackWarning          String?                 @db.Text
  allowOriginalTextView  Boolean                 @default(false)
  allowOriginalAudioPlay Boolean                 @default(false)
  status                 ContentStatus           @default(visible)
  replyCount             Int                     @default(0)
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  family                 Family                  @relation(fields: [familyId], references: [id], onDelete: Cascade)
  sender                 User                    @relation("FamilyMessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  receivers              FamilyMessageReceiver[]
  slotReceivers          FamilyMessageSlotReceiver[]
  replies                FamilyReply[]
  notifications          Notification[]
  sourceMemories          FamilyMemory[]           @relation("FamilyMemorySourceMessage")

  @@index([familyId, status, createdAt])
  @@index([senderId, status])
  @@index([riskLevel, createdAt])
}

model FamilyMessageReceiver {
  id        Int                   @id @default(autoincrement())
  messageId Int
  userId    Int
  status    MessageReceiverStatus @default(unread)
  readAt    DateTime?
  repliedAt DateTime?
  createdAt DateTime              @default(now())
  message   FamilyMessage         @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([userId, status])
}

model FamilyMessageSlotReceiver {
  id        Int                   @id @default(autoincrement())
  messageId Int
  familyId  Int
  slotKey   String                @db.VarChar(40)
  status    MessageReceiverStatus @default(unread)
  readAt    DateTime?
  repliedAt DateTime?
  createdAt DateTime              @default(now())
  message   FamilyMessage         @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, slotKey])
  @@index([familyId, slotKey, status])
}

model FamilyReply {
  id            Int            @id @default(autoincrement())
  familyId      Int
  messageId     Int
  senderId      Int
  originalText  String         @db.Text
  optimizedText String         @db.Text
  emotionTags   Json?
  aiAdvice      String?        @db.Text
  riskLevel     RiskLevel      @default(low)
  attackWarning String?        @db.Text
  status        ContentStatus  @default(visible)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  family        Family         @relation(fields: [familyId], references: [id], onDelete: Cascade)
  message       FamilyMessage  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  sender        User           @relation("FamilyReplySender", fields: [senderId], references: [id], onDelete: Cascade)
  notifications Notification[]
  sourceMemories FamilyMemory[] @relation("FamilyMemorySourceReply")

  @@index([messageId, status, createdAt])
  @@index([familyId, status])
  @@index([senderId, status])
}

model Notification {
  id        Int              @id @default(autoincrement())
  userId    Int
  actorId   Int?
  familyId  Int?
  type      NotificationType
  title     String           @db.VarChar(191)
  content   String           @db.Text
  isRead    Boolean          @default(false)
  messageId Int?
  replyId   Int?
  createdAt DateTime         @default(now())
  user      User             @relation("NotificationReceiver", fields: [userId], references: [id], onDelete: Cascade)
  actor     User?            @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)
  family    Family?          @relation(fields: [familyId], references: [id], onDelete: Cascade)
  message   FamilyMessage?   @relation(fields: [messageId], references: [id], onDelete: SetNull)
  reply     FamilyReply?     @relation(fields: [replyId], references: [id], onDelete: SetNull)

  @@index([userId, isRead, createdAt])
  @@index([familyId])
  @@index([messageId])
}

model FamilyAdminLog {
  id         Int                   @id @default(autoincrement())
  familyId   Int
  adminId    Int
  targetType FamilyAdminTargetType
  targetId   Int
  action     FamilyAdminAction
  reason     String?               @db.Text
  metadata   Json?
  createdAt  DateTime              @default(now())
  family     Family                @relation(fields: [familyId], references: [id], onDelete: Cascade)
  admin      User                  @relation("FamilyAdminLogAdmin", fields: [adminId], references: [id], onDelete: Cascade)

  @@index([familyId, createdAt])
  @@index([targetType, targetId])
}

model FamilyMemory {
  id                  Int                @id @default(autoincrement())
  familyId            Int
  scope               FamilyMemoryScope
  scopeKey            String             @db.VarChar(191)
  memberId            Int?
  relatedMemberId     Int?
  summary             String             @db.Text
  avoidPhrases        Json?
  effectivePhrases    Json?
  sensitiveTopics     Json?
  status              FamilyMemoryStatus @default(active)
  version             Int                @default(1)
  sourceMessageCount  Int                @default(0)
  sourceReplyCount    Int                @default(0)
  sourceMessageId     Int?
  sourceReplyId       Int?
  lastRefreshedAt     DateTime?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  family              Family             @relation(fields: [familyId], references: [id], onDelete: Cascade)
  member              FamilyMember?      @relation("FamilyMemoryMember", fields: [memberId], references: [id], onDelete: Cascade)
  relatedMember       FamilyMember?      @relation("FamilyMemoryRelated", fields: [relatedMemberId], references: [id], onDelete: Cascade)
  sourceMessage       FamilyMessage?     @relation("FamilyMemorySourceMessage", fields: [sourceMessageId], references: [id], onDelete: SetNull)
  sourceReply         FamilyReply?       @relation("FamilyMemorySourceReply", fields: [sourceReplyId], references: [id], onDelete: SetNull)

  @@unique([familyId, scopeKey])
  @@index([familyId, scope, status])
  @@index([memberId])
  @@index([relatedMemberId])
  @@index([sourceMessageId])
  @@index([sourceReplyId])
}
